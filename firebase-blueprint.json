{
  "entities": {
    "habit": {
      "title": "Habit",
      "description": "A habit to be tracked.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the habit" },
        "category": { "type": "string", "description": "Category of the habit" },
        "color": { "type": "string", "description": "Hex color code for the habit" },
        "frequency": { "type": "string", "description": "Frequency of the habit (e.g., daily, weekly)" },
        "sort_order": { "type": "number", "description": "Order in which to display the habit" },
        "is_active": { "type": "boolean", "description": "Whether the habit is currently active" },
        "user_id": { "type": "string", "description": "UID of the user who owns this habit" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the habit was created" }
      },
      "required": ["name", "user_id", "created_at"]
    },
    "habit_log": {
      "title": "Habit Log",
      "description": "A log entry for a specific habit on a specific date.",
      "type": "object",
      "properties": {
        "habit_id": { "type": "string", "description": "ID of the habit being logged" },
        "user_id": { "type": "string", "description": "UID of the user who owns this log" },
        "log_date": { "type": "string", "format": "date", "description": "The date of the log (YYYY-MM-DD)" },
        "status": { "type": "string", "enum": ["done", "missed", "protected"], "description": "Status of the habit for this date" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the log was created" }
      },
      "required": ["habit_id", "user_id", "log_date", "status", "created_at"]
    },
    "goal": {
      "title": "Goal",
      "description": "A specific goal to be achieved.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the goal" },
        "description": { "type": "string", "description": "Detailed description of the goal" },
        "type": { "type": "string", "enum": ["daily", "weekly", "monthly"], "description": "Type of goal" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"], "description": "Priority level" },
        "completed": { "type": "boolean", "description": "Whether the goal is completed" },
        "target_date": { "type": "string", "format": "date", "description": "Target completion date" },
        "week_start": { "type": "string", "format": "date", "description": "Start date of the week for weekly goals" },
        "month": { "type": "string", "description": "Month for monthly goals" },
        "user_id": { "type": "string", "description": "UID of the user who owns this goal" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the goal was created" }
      },
      "required": ["title", "user_id", "type", "created_at"]
    },
    "sleep_log": {
      "title": "Sleep Log",
      "description": "A log of sleep data for a specific date.",
      "type": "object",
      "properties": {
        "log_date": { "type": "string", "format": "date", "description": "The date of the log" },
        "bedtime": { "type": "string", "description": "Time the user went to bed" },
        "wake_time": { "type": "string", "description": "Time the user woke up" },
        "hours_slept": { "type": "number", "description": "Total hours of sleep" },
        "quality": { "type": "number", "description": "Quality of sleep (1-5)" },
        "mood": { "type": "string", "description": "Mood upon waking" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for the sleep session" },
        "notes": { "type": "string", "description": "Additional notes" },
        "user_id": { "type": "string", "description": "UID of the user" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the log was created" }
      },
      "required": ["log_date", "user_id", "created_at"]
    },
    "journal_entry": {
      "title": "Journal Entry",
      "description": "A daily journal entry.",
      "type": "object",
      "properties": {
        "entry_date": { "type": "string", "format": "date", "description": "The date of the entry" },
        "priority": { "type": "string", "description": "Main priority of the day" },
        "energy_word": { "type": "string", "description": "One word to describe energy level" },
        "mood": { "type": "string", "description": "Mood of the day" },
        "did_today": { "type": "array", "items": { "type": "string" }, "description": "List of things done today" },
        "what_happened": { "type": "string", "description": "Summary of what happened" },
        "went_well": { "type": "string", "description": "What went well" },
        "would_change": { "type": "string", "description": "What would be changed" },
        "grateful": { "type": "string", "description": "What the user is grateful for" },
        "day_score": { "type": "number", "description": "Score for the day (1-10)" },
        "is_win": { "type": "boolean", "description": "Whether the day was a win" },
        "user_id": { "type": "string", "description": "UID of the user" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the entry was created" }
      },
      "required": ["entry_date", "user_id", "created_at"]
    },
    "streak_protection": {
      "title": "Streak Protection",
      "description": "Records of used streak protection.",
      "type": "object",
      "properties": {
        "habit_id": { "type": "string", "description": "ID of the habit protected" },
        "used_date": { "type": "string", "format": "date", "description": "Date the protection was used" },
        "month": { "type": "string", "description": "Month the protection was used" },
        "user_id": { "type": "string", "description": "UID of the user" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the record was created" }
      },
      "required": ["habit_id", "user_id", "used_date", "created_at"]
    },
    "user": {
      "title": "User",
      "description": "User profile information and settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" },
        "why": { "type": "string", "description": "Why the user is building discipline" },
        "timezone": { "type": "string", "description": "User's timezone" },
        "sleep_target": { "type": "number", "description": "Target hours of sleep" },
        "warn_streak": { "type": "boolean", "description": "Whether to warn when streak exceeds 5 days" },
        "bedtime_reminder": { "type": "boolean", "description": "Whether bedtime reminder is enabled" },
        "current_quote_index": { "type": "number", "description": "Index of the current accountability quote" },
        "forge_score": { "type": "number", "description": "The user's current Forge Score (0-100)" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the user joined" }
      },
      "required": ["name", "email", "role", "created_at"]
    }
  },
  "firestore": {
    "/habits/{habitId}": { "schema": "habit", "description": "User habits" },
    "/habit_logs/{logId}": { "schema": "habit_log", "description": "Logs for habits" },
    "/goals/{goalId}": { "schema": "goal", "description": "User goals" },
    "/sleep_logs/{logId}": { "schema": "sleep_log", "description": "Sleep tracking logs" },
    "/journal_entries/{entryId}": { "schema": "journal_entry", "description": "Daily journal entries" },
    "/streak_protection/{protectionId}": { "schema": "streak_protection", "description": "Streak protection usage" },
    "/users/{userId}": { "schema": "user", "description": "User profiles" }
  }
}
